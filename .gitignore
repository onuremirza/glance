# Glance — .gitignore (Electron / Node)

# AI dev-tooling files (kept local, not published)
CLAUDE.md
AGENTS.md
.cursorrules
.mcp.json

# Internal docs (ADR / design / roadmap) — kept local, not published
/docs/

# Dependencies
/node_modules

# Build / packaging output
/dist
/out
/release
/build

# Runtime user data (config.json lives here; not committed)
/userData

# Debug logs
npm-debug.log*
yarn-debug.log*
*.log

# Secrets — never committed
.env
.env.*
*.key
*.pem
secrets/

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
