{
  "name": "glance",
  "version": "0.2.3",
  "description": "A minimal always-on-top overlay that shows running Claude Code sessions at a glance — status, context workload and usage limit (Windows).",
  "private": true,
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dist": "electron-builder --win nsis portable --publish never"
  },
  "keywords": [
    "claude-code",
    "electron",
    "overlay",
    "windows",
    "developer-tools",
    "monitoring"
  ],
  "author": "onuremirza",
  "license": "MIT",
  "homepage": "https://github.com/onuremirza/glance",
  "repository": {
    "type": "git",
    "url": "https://github.com/onuremirza/glance.git"
  },
  "bugs": {
    "url": "https://github.com/onuremirza/glance/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "build": {
    "appId": "com.glance.overlay",
    "productName": "Glance",
    "publish": [
      {
        "provider": "github",
        "owner": "onuremirza",
        "repo": "glance"
      }
    ],
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/*.ps1"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.ico"
    },
    "portable": {
      "unpackDirName": "glance",
      "artifactName": "Glance-${version}-portable.exe"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Glance",
      "runAfterFinish": true,
      "artifactName": "Glance-${version}-Setup.exe",
      "uninstallDisplayName": "Glance"
    }
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
